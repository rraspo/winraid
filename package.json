{
  "name": "winraid",
  "author": "rraspo",
  "repository": {
    "type": "git",
    "url": "https://github.com/rraspo/winraid"
  },
  "license": "GPL-3.0-only",
  "version": "1.4.1",
  "description": "Windows desktop app for homelab file sync — watch a local folder and push to NAS via SFTP/SMB",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src electron",
    "clean:gyp": "node -e \"require('fs').rmSync('node_modules/ssh2/lib/protocol/crypto/build/node_gyp_bins', {recursive: true, force: true})\"",
    "dist": "npm run build && npm run clean:gyp && electron-builder",
    "dist:win": "npm run build && npm run clean:gyp && electron-builder --win",
    "dist:dir": "npm run build && npm run clean:gyp && electron-builder --dir",
    "release": "node scripts/release.js",
    "tag": "node scripts/tag.js",
    "version:show": "node scripts/version.js",
    "clean": "node scripts/clean.js"
  },
  "dependencies": {
    "@visx/hierarchy": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.3.9",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/legacy-modes": "^6.4.2",
    "@eslint/js": "^9.39.3",
    "@fontsource/inter": "^5.1.0",
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@uiw/react-codemirror": "^4.23.7",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
